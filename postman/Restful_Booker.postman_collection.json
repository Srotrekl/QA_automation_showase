{
  "info": {
    "name": "Restful Booker API",
    "description": "Manuální API testy pro Restful Booker — smoke, CRUD, negative scénáře.\n\nPoužij společně s automatizovanými testy v tests/api/.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://restful-booker.herokuapp.com"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "booking_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth — získání tokenu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response obsahuje token', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('token');",
                  "    pm.expect(body.token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('token', body.token);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{base_url}}/auth"
          }
        },
        {
          "name": "POST /auth — neplatné credentials",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response obsahuje reason Bad credentials', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.reason).to.eql('Bad credentials');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"neexistujici\",\n  \"password\": \"spatne_heslo\"\n}"
            },
            "url": "{{base_url}}/auth"
          }
        }
      ]
    },
    {
      "name": "Booking CRUD",
      "item": [
        {
          "name": "GET /booking — seznam IDs",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response je neprázdný array', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array').and.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/booking"
          }
        },
        {
          "name": "POST /booking — vytvoření bookingu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response obsahuje bookingid', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('bookingid');",
                  "    pm.expect(body.booking.firstname).to.eql('Jan');",
                  "    pm.collectionVariables.set('booking_id', body.bookingid);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Jan\",\n  \"lastname\": \"Testovaci\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-10\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": "{{base_url}}/booking"
          }
        },
        {
          "name": "GET /booking/:id — detail bookingu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Správná data', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.firstname).to.eql('Jan');",
                  "    pm.expect(body.lastname).to.eql('Testovaci');",
                  "    pm.expect(body.totalprice).to.eql(150);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/booking/{{booking_id}}"
          }
        },
        {
          "name": "PUT /booking/:id — aktualizace bookingu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Firstname aktualizován', () => {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body.firstname).to.eql('Updated');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Accept", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstname\": \"Updated\",\n  \"lastname\": \"Testovaci\",\n  \"totalprice\": 150,\n  \"depositpaid\": true,\n  \"bookingdates\": {\n    \"checkin\": \"2026-06-01\",\n    \"checkout\": \"2026-06-10\"\n  },\n  \"additionalneeds\": \"Breakfast\"\n}"
            },
            "url": "{{base_url}}/booking/{{booking_id}}"
          }
        },
        {
          "name": "DELETE /booking/:id — smazání bookingu",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 201 (Created = deleted v Restful Booker)', () => {",
                  "    pm.response.to.have.status(201);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Cookie", "value": "token={{token}}" }
            ],
            "url": "{{base_url}}/booking/{{booking_id}}"
          }
        },
        {
          "name": "GET /booking/:id — ověření smazání (404)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404 — booking smazán', () => {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/booking/{{booking_id}}"
          }
        }
      ]
    },
    {
      "name": "Negative",
      "item": [
        {
          "name": "GET /booking/999999 — neexistující booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 404', () => pm.response.to.have.status(404));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": "{{base_url}}/booking/999999"
          }
        },
        {
          "name": "DELETE /booking — bez auth tokenu (403)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 403 — forbidden bez auth', () => {",
                  "    pm.expect(pm.response.code).to.be.oneOf([401, 403]);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": "{{base_url}}/booking/1"
          }
        }
      ]
    }
  ]
}
